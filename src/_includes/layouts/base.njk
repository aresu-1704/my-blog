<!doctype html>
<html lang="vi">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{ title or "Lý Thuận An" }}</title>
	<meta name="description" content="{{ description or 'Blog cá nhân của Lý Thuận An' }}">
	<meta name="google-site-verification" content="-ay34OFZJaHIiVbG8Mdt3RExouyAHVhlip_kx_XNzCk" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}">
</head>
<body>
	<header class="site-header">
		<div class="container">
			<div class="brand">
				<a href="{{ '/' | url }}" class="brand__link">Lý Thuận An</a>
			</div>
			<nav class="nav">
				<ul class="nav__list">
					<li><a class="nav__link{% if page.url == '/' %} is-active{% endif %}" href="{{ '/' | url }}">Home</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/about/') %} is-active{% endif %}" href="{{ '/about/' | url }}">About</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/resume/') %} is-active{% endif %}" href="{{ '/resume/' | url }}">Resume</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/gallery/') %} is-active{% endif %}" href="{{ '/gallery/' | url }}">Gallery</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/portfolio/') %} is-active{% endif %}" href="{{ '/portfolio/' | url }}">Portfolio</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/research/') %} is-active{% endif %}" href="{{ '/research/' | url }}">Research</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/shares/') %} is-active{% endif %}" href="{{ '/shares/' | url }}">Shares</a></li>
					<li><a class="nav__link{% if page.url.startsWith('/contact/') %} is-active{% endif %}" href="{{ '/contact/' | url }}">Contact</a></li>
				</ul>
			</nav>
		</div>
	</header>
	<main class="site-main">
		<div class="container">
			{{ content | safe }}
		</div>
	</main>
	<footer class="site-footer">
		<div class="container">
			<p>© {{ site.year }} Lý Thuận An. All rights reserved.</p>
		</div>
	</footer>
	<script src="{{ '/assets/js/main.js' | url }}" defer></script>
	</body>
</html>

